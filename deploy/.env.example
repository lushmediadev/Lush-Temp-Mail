ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
USER_USERNAME=user
USER_PASSWORD=change-me
SESSION_COOKIE_NAME=lush_temp_mail_session
SESSION_TTL_HOURS=168
SECURE_COOKIE=true

APP_BASE_URL=https://mail.lushmedia.net
TEMPMAIL_PUBLIC_DOMAIN=mail.lushmedia.net
TEMPMAIL_MAIL_DOMAIN=lushmedia.net
DEFAULT_ALIAS_HOURS=0
MESSAGE_RETENTION_DAYS=0

IMAP_HOST=mx.lushmedia.net
IMAP_PORT=993
IMAP_USERNAME=contact@lushmedia.net
IMAP_PASSWORD=change-me
SMTP_HOST=mx.lushmedia.net
SMTP_PORT=587
SMTP_USERNAME=contact@lushmedia.net
SMTP_PASSWORD=change-me
SMTP_SECURITY=starttls
SMTP_FROM_ADDRESS=contact@lushmedia.net
SMTP_FROM_NAME=LushMail
CENTRAL_MAILBOX=contact@lushmedia.net
MAIL_SYNC_ENABLED=true
MAIL_SYNC_INTERVAL_S=4
MAIL_IDLE_ENABLED=true
MAIL_IDLE_TIMEOUT_S=1500

TEMPMAIL_DATA_DIR=/app/data
TEMPMAIL_DB_PATH=/app/data/lush_temp_mail.db
LOG_LEVEL=INFO
